  "dynamicRoutes": [
    {
      "page": "/dashboard/scoring/[matchId]",
      "regex": "^/dashboard/scoring/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPmatchId": "nxtPmatchId"
      },
      "namedRegex": "^/dashboard/scoring/(?<nxtPmatchId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/matches/[id]",
      "regex": "^/matches/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
