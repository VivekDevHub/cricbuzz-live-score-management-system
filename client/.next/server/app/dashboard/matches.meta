{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/matches/layout,_N_T_/dashboard/matches/page,_N_T_/dashboard/matches"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/matches/__PAGE__",
    "/dashboard/matches",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}